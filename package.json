{
  "name": "card-goat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -p server/tsconfig.json && tsc && vite build",
    "start": "node server/dist/index.js",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "react": "latest",
    "react-dom": "latest",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "vite": "latest"
  }
}
